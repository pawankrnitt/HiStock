# .env.example — copy to .env and fill in values

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_DOCUMENTS_BUCKET=histock-documents

DYNAMODB_PROCESSED_DOCS_TABLE=histock-processed-docs

PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=histock

GROQ_API_KEY=your_groq_api_key

NEWS_API_KEY=your_news_api_key

ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# Phase 3 — Real-time (Upstash Redis)
UPSTASH_REDIS_URL=rediss://default:your_password@your-endpoint.upstash.io:6379
